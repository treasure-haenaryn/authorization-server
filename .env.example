# 환경변수 템플릿
# 이 파일을 복사해서 .env 파일을 만들고 값을 채워주세요
# cp .env.example .env

# Server
SERVER_PORT=9000

# Database
DB_URL=jdbc:postgresql://localhost:5432/authserver
DB_USERNAME=
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Signing Key — ES256(EC P-256) (dev: in-memory / prod: database)
SIGNING_KEY_SOURCE=in-memory

# TLS (prod)
SSL_ENABLED=false
SSL_KEYSTORE_PATH=
SSL_KEYSTORE_PASSWORD=

# Observability
OTLP_ENDPOINT=http://localhost:4318
OTLP_ENABLED=false
