# 환경변수 템플릿
# 이 파일을 복사해서 .env 파일을 만들고 값을 채워주세요
# cp .env.example .env

# Server
SERVER_PORT=9000

# Database
DB_URL=jdbc:postgresql://localhost:5432/authserver
DB_USERNAME=
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Signing Key — ES256(EC P-256) (dev: in-memory / prod: database)
SIGNING_KEY_SOURCE=in-memory
# source=database일 때만 사용. Base64 인코딩된 AES-256 키(32바이트).
# 생성 예: openssl rand -base64 32
ENCRYPTION_KEY=

# Authorization Server
# 발급하는 모든 토큰의 iss 클레임과 JWKS/디스커버리 엔드포인트의 기준 URL
AUTH_SERVER_ISSUER=http://localhost:9000

# TLS (prod)
SSL_ENABLED=false
SSL_KEYSTORE_PATH=
SSL_KEYSTORE_PASSWORD=

# Observability
OTLP_ENDPOINT=http://localhost:4318
OTLP_ENABLED=false
